{
  "name": "watchtofriend-desktop",
  "version": "1.4.0",
  "description": "Arkadaşlarla birlikte video izleme masaüstü uygulaması",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "icons": "powershell -ExecutionPolicy Bypass -File scripts/generate-icons.ps1 && node scripts/make-ico.mjs",
    "dist": "npm run icons && electron-vite build && electron-builder --dir && node scripts/embed-win-icon.mjs && electron-builder --win nsis zip --prepackaged release/win-unpacked",
    "deploy:hosting": "firebase deploy --only hosting"
  },
  "build": {
    "appId": "com.watch.watchtofriend.desktop",
    "productName": "WatchToFriend",
    "protocols": [
      {
        "name": "WatchToFriend Invite",
        "schemes": ["watchtofriend"]
      }
    ],
    "icon": "build/icon.ico",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis"
        },
        {
          "target": "zip"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "WatchToFriend",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "warningsAsErrors": false,
      "include": "build/installer.nsh"
    }
  },
  "dependencies": {
    "firebase": "^10.12.0"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.7.7",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "firebase-tools": "^14.0.0",
    "firebase-admin": "^13.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "png-to-ico": "^2.1.8",
    "rcedit": "^4.0.1"
  }
}
